\@writefile{toc}{\contentsline {paragraph}{Regularization path.}{4}{section*.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Four stacked panels showing the ODE posterior for $\beta _{ODE}$ as the number of independent community-network outbreaks increases ($R = 1, 5, 10, 20$, top to bottom). All panels share the same horizontal axis. The dotted vertical line marks $\beta _{true} = 0.04$ (per-contact rate; a different quantity than $\beta _{ODE}$). The dashed vertical line marks the counterfactual reference $\beta _{mf,true} \approx 1.47$ (what an unbiased ODE would recover from a uniform network of the same density). The 95\% credible interval width, annotated in each panel, shrinks fourfold from $R=1$ to $R=20$; the posterior mass does not move toward the reference. More data make the wrong model more certain.}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:more_data}{{2}{5}{Four stacked panels showing the ODE posterior for $\beta _{ODE}$ as the number of independent community-network outbreaks increases ($R = 1, 5, 10, 20$, top to bottom). All panels share the same horizontal axis. The dotted vertical line marks $\beta _{true} = 0.04$ (per-contact rate; a different quantity than $\beta _{ODE}$). The dashed vertical line marks the counterfactual reference $\beta _{mf,true} \approx 1.47$ (what an unbiased ODE would recover from a uniform network of the same density). The 95\% credible interval width, annotated in each panel, shrinks fourfold from $R=1$ to $R=20$; the posterior mass does not move toward the reference. More data make the wrong model more certain}{figure.2}{}}

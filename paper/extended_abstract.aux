\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Regularization path, shown as two panels. \textit  {Top}: within-group edge share (green) rises from uniform mixing ($1/K = 0.25$, dashed) toward 1 as $\eta $ increases. \textit  {Bottom}: ODE posterior bias (MAP $-\,\beta _{mf,true}$, red) becomes increasingly negative; absolute bias increases convexly with $\eta $. At $\eta = 0$ the network is approximately Erd\H {o}s--R\'enyi and bias is near zero; at $\eta = 3$ bias reaches $-0.48$.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:reg_path}{{3}{8}{Regularization path, shown as two panels. \textit {Top}: within-group edge share (green) rises from uniform mixing ($1/K = 0.25$, dashed) toward 1 as $\eta $ increases. \textit {Bottom}: ODE posterior bias (MAP $-\,\beta _{mf,true}$, red) becomes increasingly negative; absolute bias increases convexly with $\eta $. At $\eta = 0$ the network is approximately Erd\H {o}s--R\'enyi and bias is near zero; at $\eta = 3$ bias reaches $-0.48$}{figure.3}{}}

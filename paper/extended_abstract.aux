\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces ODE posteriors under uniform-network data (blue, ``Uniform network posterior'') and community-network data (red, ``Community network posterior''). The blue posterior sits near its reference $\beta _{mf,true}$ (dashed blue line): this is what an unbiased ODE recovers from a uniform contact structure. The red posterior concentrates well to the left of $\beta _{mf,true}$ (dashed black line): community structure causes the two-phase epidemic shape that no single-$\beta _{ODE}$ ODE can match, so the posterior is pulled toward a lower effective rate. Both posteriors are tight---the bias is misspecification, not uncertainty.}}{6}{figure.1}\protected@file@percent }
\newlabel{fig:bias_single}{{1}{6}{ODE posteriors under uniform-network data (blue, ``Uniform network posterior'') and community-network data (red, ``Community network posterior''). The blue posterior sits near its reference $\beta _{mf,true}$ (dashed blue line): this is what an unbiased ODE recovers from a uniform contact structure. The red posterior concentrates well to the left of $\beta _{mf,true}$ (dashed black line): community structure causes the two-phase epidemic shape that no single-$\beta _{ODE}$ ODE can match, so the posterior is pulled toward a lower effective rate. Both posteriors are tight---the bias is misspecification, not uncertainty}{figure.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {7}PAC-Bayesian Inference and Recoverability}{6}{section.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Four stacked panels showing the ODE posterior for $\beta _{ODE}$ as the number of independent community-network outbreaks increases ($R = 1, 5, 10, 20$, top to bottom). All panels share the same horizontal axis. All additional outbreaks are observed at the same grain (weekly aggregate incidence) and the same clock (weekly reporting). The dotted vertical line marks $\beta _{true} = 0.04$ (per-contact rate; a different quantity than $\beta _{ODE}$). The dashed vertical line marks the counterfactual reference $\beta _{mf,true} \approx 1.47$ (what an unbiased ODE would recover from a uniform network of the same density). The 95\% credible interval width shrinks fourfold from $R=1$ to $R=20$; the posterior mass does not move toward the reference. More data at the same observational grain and clock estimate the wrong reduced model more precisely.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:more_data}{{2}{7}{Four stacked panels showing the ODE posterior for $\beta _{ODE}$ as the number of independent community-network outbreaks increases ($R = 1, 5, 10, 20$, top to bottom). All panels share the same horizontal axis. All additional outbreaks are observed at the same grain (weekly aggregate incidence) and the same clock (weekly reporting). The dotted vertical line marks $\beta _{true} = 0.04$ (per-contact rate; a different quantity than $\beta _{ODE}$). The dashed vertical line marks the counterfactual reference $\beta _{mf,true} \approx 1.47$ (what an unbiased ODE would recover from a uniform network of the same density). The 95\% credible interval width shrinks fourfold from $R=1$ to $R=20$; the posterior mass does not move toward the reference. More data at the same observational grain and clock estimate the wrong reduced model more precisely}{figure.2}{}}
